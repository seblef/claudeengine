# demo.obj - unit cube centred at origin, triangulated, per-face normals
# 6 faces x 4 vertices x 2 triangles = 24 vertices, 36 indices after weld

v -1.0 -1.0  1.0
v  1.0 -1.0  1.0
v  1.0  1.0  1.0
v -1.0  1.0  1.0
v -1.0 -1.0 -1.0
v  1.0 -1.0 -1.0
v  1.0  1.0 -1.0
v -1.0  1.0 -1.0

vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0

vn  0.0  0.0  1.0
vn  0.0  0.0 -1.0
vn  0.0  1.0  0.0
vn  0.0 -1.0  0.0
vn  1.0  0.0  0.0
vn -1.0  0.0  0.0

# +Z front
f 1/1/1 2/2/1 3/3/1
f 1/1/1 3/3/1 4/4/1
# -Z back
f 6/1/2 5/2/2 8/3/2
f 6/1/2 8/3/2 7/4/2
# +Y top
f 4/1/3 3/2/3 7/3/3
f 4/1/3 7/3/3 8/4/3
# -Y bottom
f 5/1/4 6/2/4 2/3/4
f 5/1/4 2/3/4 1/4/4
# +X right
f 2/1/5 6/2/5 7/3/5
f 2/1/5 7/3/5 3/4/5
# -X left
f 5/1/6 1/2/6 4/3/6
f 5/1/6 4/3/6 8/4/6
