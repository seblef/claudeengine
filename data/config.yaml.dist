graphics:
  windowed: true
  width: 1200
  height: 1000
editor:
  autosave_interval_seconds: 120
  recent_maps:
    - /home/seb/dev/claudeengine/data/maps/demo3.map.yaml
    - /home/seb/dev/claudeengine/data/maps/generate.map.yaml
    - /home/seb/dev/claudeengine/data/maps/normal.yaml.map.yaml
    - /home/seb/dev/claudeengine/data/maps/demo.map.yaml
    - /home/seb/dev/claudeengine/data/maps/test3.yaml.map.yaml
shadows:
  2d_pool:
    slots_per_tier: 8
    tiers: [64, 128, 256, 512, 1024]
  cube_pool:
    slots_per_tier: 4
    tiers: [64, 128, 256, 512]
  screen_size_thresholds:
    t64: 20
    t128: 50
    t256: 100
    t512: 200
    t1024: 350
    min: 10
  hysteresis_factor: 0.8
post_process:
  bloom: true
  eye_adaptation: true
player:
  capsule_radius: 0.8
  capsule_half_height: 1.8
  eye_offset: 0.3
  move_speed: 10.0
  mouse_sensitivity: 0.002
  jump_speed: 7.0
  gravity: 9.81